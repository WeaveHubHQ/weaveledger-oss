{
  "name": "weaveledger-api",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute weaveledger-db --file=./migrations/0001_initial.sql",
    "db:migrate:local": "wrangler d1 execute weaveledger-db --local --file=./migrations/0001_initial.sql",
    "db:migrate:009": "wrangler d1 execute weaveledger-db --file=./migrations/0009_subscriptions.sql",
    "db:migrate:009:local": "wrangler d1 execute weaveledger-db --local --file=./migrations/0009_subscriptions.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240512.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.71.0"
  }
}
